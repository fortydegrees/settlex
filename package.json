{
  "name": "settlex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm -C game-core build",
    "dev": "next dev",
    "dev:log": "mkdir -p .logs && pnpm dev 2>&1 | tee .logs/dev.log",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "verify": "pnpm -C game-core build && pnpm exec vitest run && pnpm lint",
    "serve": "node server/server.js"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@react-spring/web": "^9.7.3",
    "@settlex/game-core": "workspace:*",
    "assert": "^2.1.0",
    "autoprefixer": "10.4.15",
    "bgio-effects": "^0.7.1",
    "boardgame.io": "^0.50.2",
    "canvas-confetti": "^1.9.4",
    "esm": "^3.2.25",
    "framer-motion": "^10.16.4",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "jsnetworkx": "^0.3.4",
    "koa-body": "^7.0.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "next": "^13.5.4",
    "next-images": "^1.8.5",
    "postcss": "8.4.29",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-hexgrid": "^2.0.1",
