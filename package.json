{
  "name": "settlex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.13.2",
  "scripts": {
    "predev": "pnpm -C game-core build",
    "dev": "next dev",
    "dev:log": "mkdir -p .logs && pnpm dev 2>&1 | tee .logs/dev.log",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgres://settlehex:settlehex@localhost:55432/settlehex} node scripts/db/migrate.mjs",
    "db:migrate:test": "DATABASE_URL=${DATABASE_URL:-postgres://settlehex:settlehex@localhost:55432/settlehex_test} node scripts/db/migrate.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:app": "node scripts/run-vitest-app-tests.mjs",
    "test:non-app": "pnpm exec vitest run game-core/src server lib ai react-zoom-pan-pinch --reporter=dot",
    "verify": "pnpm -C game-core build && pnpm run test:non-app && pnpm run test:app && pnpm lint",
    "serve": "node server/server.js",
    "release:check": "node scripts/release/check-release.mjs",
    "release:status": "node scripts/release/status.mjs",
    "docs:index": "node scripts/write-docs-index.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@react-spring/web": "^9.7.3",
    "@settlex/game-core": "workspace:*",
    "assert": "^2.1.0",
    "autoprefixer": "10.4.15",
    "bgio-effects": "^0.7.1",
    "boardgame.io": "^0.50.2",
    "canvas-confetti": "^1.9.4",
    "esm": "^3.2.25",
    "framer-motion": "^10.16.4",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "jsnetworkx": "^0.3.4",
    "koa-body": "^7.0.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "next": "^13.5.4",
    "next-images": "^1.8.5",
    "pg": "^8.20.0",
    "postcss": "8.4.29",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-hexgrid": "^2.0.1",
    "react-use-gesture": "^9.1.3",
    "react-zoom-pan-pinch": "^3.1.0",
    "tailwindcss": "3.3.3",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "18.2.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "tailwind-clip-path": "^1.0.0",
    "typescript": "5.2.2",
    "vitest": "^1.6.0"
  }
}
