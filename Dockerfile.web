FROM node:20-bookworm-slim AS base

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

RUN corepack enable
WORKDIR /app

FROM base AS deps

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY next.config.js ./
COPY game-core/package.json game-core/package.json
RUN pnpm install --frozen-lockfile

FROM deps AS build

ARG SETTLEX_RELEASE_VERSION=1
ARG SETTLEX_BUILD_SHA=local
ARG SETTLEX_BUILD_DATE=
ENV NEXT_PUBLIC_SETTLEX_RELEASE_VERSION=$SETTLEX_RELEASE_VERSION
ENV NEXT_PUBLIC_SETTLEX_BUILD_SHA=$SETTLEX_BUILD_SHA
ENV NEXT_PUBLIC_SETTLEX_BUILD_DATE=$SETTLEX_BUILD_DATE

COPY . .
RUN pnpm -C game-core build && pnpm build

FROM base AS runner

ENV NODE_ENV=production

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY next.config.js ./
COPY game-core/package.json game-core/package.json
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/game-core ./game-core
COPY --from=build /app/scripts ./scripts
COPY --from=build /app/lib/server/db ./lib/server/db
COPY --from=build /app/public ./public
COPY --from=build /app/.next ./.next

EXPOSE 3000

CMD ["pnpm", "exec", "next", "start", "-H", "0.0.0.0", "-p", "3000"]
